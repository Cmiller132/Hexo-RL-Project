    "react-dom": "^18.2.0",
    "react-error-boundary": "^6.1.1",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "zod": "^4.4.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "jsdom": "^29.1.1",
    "msw": "^2.14.2",
