{
  "name": "hexorl-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "gen:api": "openapi-typescript ${DASHBOARD_API_URL:-http://127.0.0.1:8765/openapi.json} -o src/api/schema.d.ts",
